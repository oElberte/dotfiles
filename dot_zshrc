# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

source /usr/share/cachyos-zsh-config/cachyos-config.zsh

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

export PATH="/home/dev/fvm/bin:$PATH"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
export PATH="$HOME/.local/bin:$PATH"

# pnpm
export PNPM_HOME="/home/dev/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

# bun completions
[ -s "/home/dev/.bun/_bun" ] && source "/home/dev/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
export CHROME_EXECUTABLE=/usr/bin/google-chrome-stable

alias claude-mem='bun "/home/dev/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs"'
export PATH="$HOME/.opencode/bin:$PATH"
# Factory API keys (NOT chezmoi-managed, keep local)
[ -f "$HOME/.config/factory-keys.env" ] && source "$HOME/.config/factory-keys.env"

# Qwen3.6 35B A3B APEX - RX 9070 XT - 262K TurboQuant
qwen262k() {
  cd "$HOME/src/llama-cpp-turboquant" || return 1

  local MODEL="$HOME/models/qwen3.6-apex/Qwen3.6-35B-A3B-APEX-I-Compact.gguf"
  local MMPROJ="$HOME/models/qwen3.6-apex/mmproj.gguf"

  HIP_VISIBLE_DEVICES=0 ./build/bin/llama-server \
    -m "$MODEL" \
    --mmproj "$MMPROJ" \
    --alias qwen3.6-35b-a3b-apex-262k-rx9070xt-turbo3-coding \
    --host 127.0.0.1 \
    --port 8080 \
    --jinja \
    -ngl 999 \
    --ctx-size 262144 \
    -fa on \
    --cache-type-k turbo3 \
    --cache-type-v turbo3 \
    --n-cpu-moe 22 \
    --threads 8 \
    --threads-batch 12 \
    --batch-size 512 \
    --ubatch-size 256 \
    --parallel 1 \
    --cache-reuse 256 \
    --metrics \
    --temp 0.3 \
    --top-p 0.9 \
    --top-k 20 \
    --min-p 0.0 \
    --presence-penalty 0.0 \
    --repeat-penalty 1.05
}


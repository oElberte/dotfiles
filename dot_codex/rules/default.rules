prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["flutter", "test"], decision="allow")
prefix_rule(pattern=["fvm", "flutter", "test"], decision="allow")
prefix_rule(pattern=["fvm", "dart", "run", "build_runner"], decision="allow")
prefix_rule(pattern=["flutter", "analyze"], decision="allow")
prefix_rule(pattern=["fvm", "flutter", "analyze"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["fvm", "dart", "format"], decision="allow")
